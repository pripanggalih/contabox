{
  "name": "contabox",
  "version": "0.1.0",
  "description": "Advanced Firefox container manager. Multi-Account Containers + SessionBox killer.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "build:prod": "tsc --noEmit && cross-env NODE_ENV=production vite build",
    "preview": "vite preview",
    "package": "pnpm build:prod && web-ext build --source-dir=dist --artifacts-dir=web-ext-artifacts --overwrite-dest",
    "web-ext": "web-ext run --source-dir=dist --target=firefox-desktop",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write . && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "version:bump": "node scripts/bump-version.mjs",
    "sign:listed": "pnpm build:prod && web-ext sign --source-dir=dist --artifacts-dir=web-ext-artifacts --channel=listed --api-key=$AMO_JWT_ISSUER --api-secret=$AMO_JWT_SECRET",
    "sign:unlisted": "pnpm build:prod && web-ext sign --source-dir=dist --artifacts-dir=web-ext-artifacts --channel=unlisted --api-key=$AMO_JWT_ISSUER --api-secret=$AMO_JWT_SECRET",
    "lint:ext": "web-ext lint --source-dir=dist"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "cmdk": "^1.0.0",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-virtuoso": "^4.12.3",
    "totp-generator": "^1.0.0",
    "webextension-polyfill": "^0.12.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.48.2",
    "@tailwindcss/vite": "^4.0.0-beta.4",
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/webextension-polyfill": "^0.12.1",
    "@vitejs/plugin-react": "^4.3.3",
    "cross-env": "^10.1.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0-beta.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.5",
    "web-ext": "^8.3.0"
  }
}
