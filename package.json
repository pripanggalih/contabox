{
  "name": "contabox",
  "version": "0.1.0",
  "description": "Advanced Firefox container manager. Multi-Account Containers + SessionBox killer.",
  "license": "MIT",
  "author": "Muhammad Wahyu Pripanggalih",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pripanggalih/contabox.git"
  },
  "homepage": "https://pripanggalih.github.io/contabox/",
  "bugs": {
    "url": "https://github.com/pripanggalih/contabox/issues"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "build:landing": "vite build --config vite.landing.config.ts",
    "build:prod": "tsc --noEmit && cross-env NODE_ENV=production vite build",
    "preview": "vite preview",
    "package": "pnpm build:prod && web-ext build --source-dir=dist --artifacts-dir=web-ext-artifacts --overwrite-dest",
    "web-ext": "web-ext run --source-dir=dist --target=firefox-desktop",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write . && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "version:bump": "node scripts/bump-version.mjs",
    "sign:listed": "pnpm build:prod && web-ext sign --source-dir=dist --artifacts-dir=web-ext-artifacts --channel=listed --api-key=$AMO_JWT_ISSUER --api-secret=$AMO_JWT_SECRET",
    "sign:unlisted": "pnpm build:prod && web-ext sign --source-dir=dist --artifacts-dir=web-ext-artifacts --channel=unlisted --api-key=$AMO_JWT_ISSUER --api-secret=$AMO_JWT_SECRET",
    "lint:ext": "web-ext lint --source-dir=dist"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "cmdk": "^1.0.0",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-virtuoso": "^4.18.10",
    "webextension-polyfill": "^0.12.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "packageManager": "pnpm@11.10.0",
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.1",
    "@vitejs/plugin-react": "^6.0.3",
    "cross-env": "^10.1.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "web-ext": "^10.4.0"
  }
}
