{
  "manifest_version": 3,
  "name": "Contabox",
  "version": "0.1.0",
  "description": "Advanced Firefox container manager. Bulk ops, proxy-per-container, fingerprint, snapshots, templates.",
  "browser_specific_settings": {
    "gecko": {
      "id": "contabox@galih.dev",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "contextualIdentities",
    "cookies",
    "storage",
    "tabs",
    "tabHide",
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "proxy",
    "scripting",
    "alarms",
    "idle",
    "privacy"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/autofill.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "sidebar_action": {
    "default_panel": "src/sidebar/index.html",
    "default_title": "Contabox",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Contabox",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": { "default": "Ctrl+Shift+E" },
      "description": "Toggle Contabox sidebar"
    },
    "open-palette": {
      "suggested_key": { "default": "Ctrl+K", "mac": "Command+K" },
      "description": "Open command palette"
    },
    "new-container": {
      "suggested_key": { "default": "Ctrl+Shift+C" },
      "description": "Create new container"
    },
    "lock-all": {
      "suggested_key": { "default": "Ctrl+Shift+L" },
      "description": "Lock all containers"
    }
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; object-src 'none'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https:;"
  }
}
